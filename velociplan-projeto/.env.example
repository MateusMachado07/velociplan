# ============================================================
# VelociPlan — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git — it contains secret keys.
# ============================================================


# ── Anthropic (Claude AI) ──────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...


# ── Stripe ────────────────────────────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
# Use the TEST keys (pk_test_... / sk_test_...) during development.
# Switch to LIVE keys (pk_live_... / sk_live_...) only in production.

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — generated when you create a webhook endpoint in Stripe.
# For local development, use the Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook
# The CLI will print the webhook secret for you.
STRIPE_WEBHOOK_SECRET=whsec_...


# ── Pricing ───────────────────────────────────────────────
# Price per plan in EUR. Change this to adjust the price.
PLAN_PRICE_EUR=9.99


# ── App ───────────────────────────────────────────────────
# The full URL of your app. Used by Stripe to redirect after payment.
# For local development, use: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
